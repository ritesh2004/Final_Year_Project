{
  "compilerOptions": {
      "module": "CommonJS",
      "esModuleInterop": true,
      "target": "es2020",
      "moduleResolution": "Node",
      "sourceMap": true,
      "outDir": "dist",
      "rootDir": "./src",
      "resolveJsonModule": true,
      "strict": true,
      "skipLibCheck": true
  },
  "lib": [
      "es2020"
  ],
  "include": [
      "src/**/*.ts"
  ]
}